### Find all films with pagination queries
# GET /films
# Sends an array of films.
GET {{localBaseUrl}}/films
?limit=25
&page=1
&orderBy=nameAsc
&tag=decade-1930s
&tag=genre-drama

### Find recent films
# GET /films/recent
# Sends array of most recent films.
GET {{localBaseUrl}}/films/recent

### Find a single film
# GET /films/:slug
# Sends a single film with Article, Person, Studio, Tag relations
GET {{localBaseUrl}}/films/the-americano-1916